# Copy to .env and fill in your Google Cloud OAuth credentials
# Get them from: https://console.cloud.google.com/apis/credentials

# Web application OAuth client ID (required for Google Sign-In)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_web_client_id.apps.googleusercontent.com

# Also update app.json: replace YOUR_IOS_CLIENT_ID in the Google Sign-In plugin
# with your iOS OAuth client's URL scheme (e.g. com.googleusercontent.apps.XXXXX)
