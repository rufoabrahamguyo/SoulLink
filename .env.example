# Copy to `.env` in the project root (never commit `.env`).
# Expo loads EXPO_PUBLIC_* at build time — restart Metro after changes.

# Google Cloud → OAuth 2.0 → Web application client ID
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_web_client_id.apps.googleusercontent.com

# Google Cloud → OAuth 2.0 → iOS client ID (same bundle ID as app.json → ios.bundleIdentifier)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your_ios_client_id.apps.googleusercontent.com
